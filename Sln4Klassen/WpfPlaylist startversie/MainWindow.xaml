<Window x:Class="WpfPlaylist.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfPlaylist"
        mc:Ignorable="d"
        Title="MainWindow" Height="430" Width="650">
    <Grid x:Name="grdMain" Background="AntiqueWhite">
        <ListBox x:Name="lbxSongs" HorizontalAlignment="Left" VerticalAlignment="Top" Width="350" Height="200" Margin="10,10,0,0" SelectionChanged="LbxSongs_SelectionChanged" />
        <Button x:Name="btnPlay" IsEnabled="False" Content="PLAY" Padding="10,5" HorizontalAlignment="Left" Margin="245,230,0,0" VerticalAlignment="Top" Click="BtnPlay_Click"/>
        <Button x:Name="btnStop" IsEnabled="False" Content="STOP" Padding="10,5" HorizontalAlignment="Left" Margin="310,230,0,0" VerticalAlignment="Top" Click="BtnStop_Click"/>
        <Slider x:Name="sldVolume" Maximum="100" Minimum="0" TickFrequency="5" Value="50" IsSnapToTickEnabled="True" HorizontalAlignment="Left" Margin="20,280,0,0" VerticalAlignment="Top" Width="340" ValueChanged="Slider_ValueChanged"/>
        <TextBlock HorizontalAlignment="Left" Margin="282,310,0,0" TextWrapping="Wrap" Text="Volume:" VerticalAlignment="Top"/>
        <TextBlock x:Name="txtVolume" HorizontalAlignment="Left" Margin="342,310,0,0" TextWrapping="Wrap" Text="50" VerticalAlignment="Top"/>
        <TextBlock x:Name="txtMessage" Text="" FontStyle="Italic" FontSize="16" HorizontalAlignment="Left" Margin="10,350,0,0" VerticalAlignment="Top"/>
        <Image x:Name="imgArtist" HorizontalAlignment="Right" Height="200" Margin="10,10,10,10" VerticalAlignment="Top" Width="200"/>
        <TextBlock x:Name="txtArtist" HorizontalAlignment="Right" Margin="10" TextWrapping="Wrap" Text="" VerticalAlignment="Bottom" Height="170" Width="200"/>
    </Grid>
</Window>
