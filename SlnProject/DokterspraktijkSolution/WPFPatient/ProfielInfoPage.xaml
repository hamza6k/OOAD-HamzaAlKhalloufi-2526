<Page x:Class="WPFPatient.ProfielInfoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Mijn Profiel"
      Loaded="Page_Loaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Mijn profiel"
                       FontSize="22" FontWeight="Bold" Foreground="#1A5276"
                       Margin="0,0,0,24"/>

            <!-- Kaart met profielgegevens -->
            <Border Grid.Row="1"
                    Background="White" CornerRadius="10"
                    Padding="24" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2"
                                      Color="#CCCCCC" Opacity="0.5"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Profielfoto -->
                    <Border Grid.Column="0" Width="120" Height="120"
                            Margin="0,0,30,0" VerticalAlignment="Top">
                        <Border.Clip>
                            <EllipseGeometry Center="60,60" RadiusX="60" RadiusY="60"/>
                        </Border.Clip>
                        <Image x:Name="ImgProfielfoto"
                               Width="120" Height="120"
                               Stretch="UniformToFill"/>
                    </Border>

                    <!-- Gegevens -->
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="TxtNaam"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="#1A5276" Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Geslacht:"
                                       FontWeight="SemiBold" Foreground="#5D6D7E"
                                       Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtGeslacht"
                                       Foreground="#2C3E50" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Geboortedatum:"
                                       FontWeight="SemiBold" Foreground="#5D6D7E"
                                       Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtGeboortedatum"
                                       Foreground="#2C3E50" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="GSM:"
                                       FontWeight="SemiBold" Foreground="#5D6D7E"
                                       Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtGsm"
                                       Foreground="#2C3E50" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="E-mailadres:"
                                       FontWeight="SemiBold" Foreground="#5D6D7E"
                                       Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TxtEmail"
                                       Foreground="#2C3E50" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Notificaties:"
                                       FontWeight="SemiBold" Foreground="#5D6D7E"
                                       Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TxtNotificaties"
                                       Foreground="#2C3E50" Margin="0,0,0,8"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Knop Bewerken -->
            <StackPanel Grid.Row="2" Orientation="Horizontal">
                <Button x:Name="BtnBewerken" Content="Bewerken"
                        Width="130" Height="38"
                        Background="#1A5276" Foreground="White"
                        BorderThickness="0" FontWeight="Bold" FontSize="14"
                        Click="BtnBewerken_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
