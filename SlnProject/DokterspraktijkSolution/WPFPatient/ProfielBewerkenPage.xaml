<Page x:Class="WPFPatient.ProfielBewerkenPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Profiel Bewerken"
      Loaded="Page_Loaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Profiel bewerken"
                       FontSize="22" FontWeight="Bold" Foreground="#1A5276"
                       Margin="0,0,0,24"/>

            <!-- Formulier -->
            <Border Grid.Row="1"
                    Background="White" CornerRadius="10"
                    Padding="24" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2"
                                      Color="#CCCCCC" Opacity="0.5"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Voornaam -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Voornaam:"
                               FontWeight="SemiBold" Foreground="#5D6D7E"
                               VerticalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtVoornaam"
                             Height="32" Padding="6,4" FontSize="13"
                             Margin="0,0,0,12"/>

                    <!-- Achternaam -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Achternaam:"
                               FontWeight="SemiBold" Foreground="#5D6D7E"
                               VerticalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtAchternaam"
                             Height="32" Padding="6,4" FontSize="13"
                             Margin="0,0,0,12"/>

                    <!-- Geslacht -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Geslacht:"
                               FontWeight="SemiBold" Foreground="#5D6D7E"
                               VerticalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtGeslacht"
                             Height="32" Padding="6,4" FontSize="13"
                             Margin="0,0,0,12"/>

                    <!-- GSM -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="GSM:"
                               FontWeight="SemiBold" Foreground="#5D6D7E"
                               VerticalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtGsm"
                             Height="32" Padding="6,4" FontSize="13"
                             Margin="0,0,0,12"/>

                    <!-- Email -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="E-mailadres:"
                               FontWeight="SemiBold" Foreground="#5D6D7E"
                               VerticalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="TxtEmail"
                             Height="32" Padding="6,4" FontSize="13"
                             Margin="0,0,0,12"/>

                    <!-- Geboortedatum -->
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Geboortedatum:"
                               FontWeight="SemiBold" Foreground="#5D6D7E"
                               VerticalAlignment="Center" Margin="0,0,0,12"/>
                    <DatePicker Grid.Row="5" Grid.Column="1" x:Name="DpGeboortedatum"
                                Height="32" FontSize="13"
                                Margin="0,0,0,12"/>

                    <!-- Notificaties -->
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Notificaties:"
                               FontWeight="SemiBold" Foreground="#5D6D7E"
                               VerticalAlignment="Center" Margin="0,0,0,12"/>
                    <ComboBox Grid.Row="6" Grid.Column="1" x:Name="CmbNotificaties"
                              Height="32" FontSize="13"
                              Margin="0,0,0,12"/>

                    <!-- Profielfoto -->
                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Profielfoto:"
                               FontWeight="SemiBold" Foreground="#5D6D7E"
                               VerticalAlignment="Top" Margin="0,4,0,12"/>
                    <StackPanel Grid.Row="7" Grid.Column="1"
                                Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="80" Height="80" Margin="0,0,12,0">
                            <Border.Clip>
                                <EllipseGeometry Center="40,40" RadiusX="40" RadiusY="40"/>
                            </Border.Clip>
                            <Image x:Name="ImgFotoVoorbeeld"
                                   Width="80" Height="80"
                                   Stretch="UniformToFill"/>
                        </Border>
                        <Button x:Name="BtnFotoUploaden" Content="Foto uploaden"
                                Width="120" Height="32"
                                Background="#2471A3" Foreground="White"
                                BorderThickness="0" VerticalAlignment="Bottom"
                                Click="BtnFotoUploaden_Click"/>
                    </StackPanel>

                    <!-- Wachtwoord (optioneel) -->
                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Nieuw wachtwoord:"
                               FontWeight="SemiBold" Foreground="#5D6D7E"
                               VerticalAlignment="Center" Margin="0,0,0,0"/>
                    <StackPanel Grid.Row="8" Grid.Column="1">
                        <PasswordBox x:Name="PbxWachtwoord"
                                     Height="32" Padding="6,4" FontSize="13"/>
                        <TextBlock Text="Laat leeg om huidig wachtwoord te bewaren."
                                   FontSize="11" Foreground="#7F8C8D"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Validatie en fout -->
            <TextBlock Grid.Row="2" x:Name="TxtValidatie"
                       Foreground="#E67E22" FontSize="13"
                       TextWrapping="Wrap" Margin="0,0,0,6"/>
            <TextBlock Grid.Row="3" x:Name="TxtFout"
                       Foreground="#C0392B" FontSize="13"
                       TextWrapping="Wrap" Visibility="Collapsed"
                       Margin="0,0,0,10"/>

            <!-- Knoppen -->
            <StackPanel Grid.Row="4" Orientation="Horizontal">
                <Button x:Name="BtnOpslaan" Content="Opslaan"
                        Width="120" Height="38"
                        Background="#1A5276" Foreground="White"
                        BorderThickness="0" FontWeight="Bold" FontSize="14"
                        Click="BtnOpslaan_Click" Margin="0,0,12,0"/>
                <Button x:Name="BtnAnnuleren" Content="Annuleren"
                        Width="100" Height="38"
                        Background="#7F8C8D" Foreground="White"
                        BorderThickness="0"
                        Click="BtnAnnuleren_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
