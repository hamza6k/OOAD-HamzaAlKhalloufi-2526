<Page x:Class="WPFPatient.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Inloggen">

    <Grid Background="#F4F6F8">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="380">

            <!-- Titel -->
            <TextBlock Text="Inloggen"
                       FontSize="26" FontWeight="Bold"
                       Foreground="#1A5276"
                       TextAlignment="Center"
                       Margin="0,0,0,6"/>

            <TextBlock Text="Meld u aan met uw patiëntenaccount"
                       FontSize="13" Foreground="#7F8C8D"
                       TextAlignment="Center"
                       Margin="0,0,0,28"/>

            <!-- Loginformulier -->
            <Border Background="White"
                    CornerRadius="8"
                    Padding="32,28">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2"
                                      Opacity="0.08" Color="Black"/>
                </Border.Effect>
                <StackPanel>

                    <!-- E-mailadres -->
                    <TextBlock Text="E-mailadres"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#555"
                               Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtEmail"
                             Text="rogier.vanderlinde@odisee.be"
                             FontSize="13" Padding="10,8"
                             BorderBrush="#CCC" BorderThickness="1"
                             Margin="0,0,0,16"/>

                    <!-- Wachtwoord -->
                    <TextBlock Text="Wachtwoord"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#555"
                               Margin="0,0,0,4"/>
                    <PasswordBox x:Name="PbxWachtwoord"
                                 FontSize="13" Padding="10,8"
                                 BorderBrush="#CCC" BorderThickness="1"
                                 Margin="0,0,0,8"/>

                    <!-- Validatiefoutmelding (lege velden) -->
                    <TextBlock x:Name="TxtValidatie"
                               Foreground="#E67E22"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,0,0,4"/>

                    <!-- Inlogfoutmelding (verkeerde gegevens of DB-fout), standaard verborgen -->
                    <TextBlock x:Name="TxtFout"
                               Foreground="#C0392B"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Margin="0,0,0,16"/>

                    <!-- Inlogknop -->
                    <Button x:Name="BtnInloggen"
                            Content="Inloggen"
                            Click="BtnInloggen_Click"
                            Height="40"
                            Background="#1A5276" Foreground="White"
                            FontSize="14" FontWeight="SemiBold"
                            BorderThickness="0"
                            Margin="0,8,0,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</Page>
