<Page x:Class="WPFDokter.PatientenOverzichtPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Patiënten"
      Background="#F4F6F8"
      Loaded="Page_Loaded">

    <Grid Margin="24,20,24,12">
        <Grid.RowDefinitions>
            <!-- Zoekbalk + knoppen -->
            <RowDefinition Height="Auto"/>
            <!-- Patiëntenkaartjes -->
            <RowDefinition Height="*"/>
            <!-- Foutmelding -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== Zoekbalk ===== -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">

            <TextBox x:Name="TxtZoeken"
                     Width="280" Height="36"
                     Padding="10,0"
                     FontSize="13"
                     VerticalContentAlignment="Center"
                     BorderBrush="#CCC" BorderThickness="1"
                     Margin="0,0,8,0"/>

            <Button x:Name="BtnZoeken"
                    Content="Zoeken"
                    Click="BtnZoeken_Click"
                    Height="36" Padding="18,0"
                    Background="#2980B9" Foreground="White"
                    FontSize="13" FontWeight="SemiBold"
                    BorderThickness="0" Margin="0,0,8,0"/>

            <Button x:Name="BtnNieuwePatient"
                    Content="+ Nieuwe patiënt"
                    Click="BtnNieuwePatient_Click"
                    Height="36" Padding="18,0"
                    Background="#27AE60" Foreground="White"
                    FontSize="13" FontWeight="SemiBold"
                    BorderThickness="0"/>
        </StackPanel>

        <!-- ===== Kaartjes in ScrollViewer ===== -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <!-- PatiëntenPanel: kaartjes worden dynamisch toegevoegd in code-behind -->
            <WrapPanel x:Name="PatientenPanel"
                       Orientation="Horizontal"/>
        </ScrollViewer>

        <!-- ===== Foutmelding (standaard verborgen) ===== -->
        <TextBlock x:Name="TxtFout"
                   Grid.Row="2"
                   Foreground="#C0392B"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"
                   Margin="0,8,0,0"/>
    </Grid>
</Page>
