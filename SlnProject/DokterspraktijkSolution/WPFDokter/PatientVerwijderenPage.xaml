<Page x:Class="WPFDokter.PatientVerwijderenPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Patiënt verwijderen"
      Background="#F4F6F8">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Paginatitel -->
        <TextBlock Grid.Row="0"
                   Text="Patiënt verwijderen"
                   FontSize="22" FontWeight="Bold"
                   Foreground="#2C3E50"
                   Margin="0,0,0,20"/>

        <!-- Bevestigingskaart -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                Padding="32,28"
                MaxWidth="560"
                HorizontalAlignment="Left">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Color="Black"/>
            </Border.Effect>

            <StackPanel>

                <!-- Naam van de te verwijderen patiënt -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="Patiënt:"
                               FontWeight="SemiBold" FontSize="14"
                               Foreground="#555" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TxtPatientNaam"
                               FontSize="14" FontWeight="Bold"
                               Foreground="#2C3E50"/>
                </StackPanel>

                <!-- Waarschuwingstekst -->
                <Border Background="#FDEDEC"
                        BorderBrush="#E74C3C" BorderThickness="1"
                        CornerRadius="4" Padding="14,12"
                        Margin="0,0,0,24">
                    <TextBlock TextWrapping="Wrap"
                               FontSize="13" Foreground="#922B21"
                               LineHeight="22">
                        Bent u zeker dat u deze patiënt wilt verwijderen?
                        <LineBreak/>
                        Dit verwijdert ook alle gekoppelde afspraken.
                        <LineBreak/>
                        <Run FontWeight="SemiBold">Deze actie kan niet ongedaan worden gemaakt.</Run>
                    </TextBlock>
                </Border>

                <!-- Foutmelding (standaard verborgen) -->
                <TextBlock x:Name="TxtFout"
                           Foreground="#C0392B"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"
                           Margin="0,0,0,12"/>

                <!-- Actieknoppen -->
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnVerwijderen"
                            Content="Verwijderen"
                            Click="BtnVerwijderen_Click"
                            Height="38" Padding="22,0"
                            Background="#C0392B" Foreground="White"
                            FontSize="13" FontWeight="SemiBold"
                            BorderThickness="0" Margin="0,0,10,0"/>
                    <Button x:Name="BtnAnnuleren"
                            Content="Annuleren"
                            Click="BtnAnnuleren_Click"
                            Height="38" Padding="22,0"
                            Background="#95A5A6" Foreground="White"
                            FontSize="13" FontWeight="SemiBold"
                            BorderThickness="0"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Page>
