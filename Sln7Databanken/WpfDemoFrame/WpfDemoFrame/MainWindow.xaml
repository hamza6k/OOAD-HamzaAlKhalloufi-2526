<Window x:Class="WpfDemoFrame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfDemoFrame"
        mc:Ignorable="d"
        Title="Page/Frame demo" Height="450" Width="800">
<Grid Background="#FFF3EBEB">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="150" />
        <ColumnDefinition Width="1*" />
    </Grid.ColumnDefinitions>
    <Frame x:Name="frmMain" Grid.Column="1" NavigationUIVisibility="Hidden" Margin="10" Background="White"/>
    <StackPanel Grid.Column="0" x:Name="spMenu" Margin="20,10">
        <Button x:Name="btnHome" Content="🏠 Home" Padding="5" Margin="0,0,0,20" Click="BtnHome_Click" />
        <Button x:Name="btnProducts" Content="🛒 Producten" Padding="5" Margin="0,0,0,20" Click="BtnProducts_Click" />
        <Button x:Name="btnAbout" Content="💡Over" Padding="5" Margin="0,0,0,20" Click="BtnAbout_Click" />
    </StackPanel>
</Grid>
</Window>
